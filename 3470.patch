+    }
+
+    void parse(const char *data, SceSize dataLen) {
+        assert(dataLen >= sizeof(header) + 0x8);
+        dataBuffer.resize(dataLen - sizeof(header) - 0x8);
+
+        header.parse(data, dataLen);
+        memcpy(dataBuffer.data(), data + sizeof(header), dataBuffer.size());
