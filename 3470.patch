+
+    void parse(const char *data, SceSize dataLen) {
+        assert(dataLen >= sizeof(SceNetAdhocMatchingMessageHeader));
+
+        memcpy(&one, data, sizeof(uint8_t));
+        memcpy(&type, data + 0x1, sizeof(SceNetAdhocMatchingPacketType));
